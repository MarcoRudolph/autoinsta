# Fly.io / Docker: Telegram MTProto worker only (no Next.js build).
# Deploy: fly apps create <name> && fly secrets set ... && fly deploy -c fly.telegram-worker.toml
FROM node:22-bookworm-slim
WORKDIR /app

COPY package.json package-lock.json ./
# tsx lives in devDependencies; full install keeps the worker image simple.
RUN npm ci

COPY tsconfig.json ./
COPY src ./src

ENV NODE_ENV=production
EXPOSE 8080
CMD ["npx", "tsx", "src/scripts/telegram-user-worker.ts"]
