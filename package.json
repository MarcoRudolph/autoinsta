{
  "name": "rudolpho-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run cf:assert-workers && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test src/lib/**/*.test.ts",
    "test:instagram": "tsx --test src/lib/instagram/*.test.ts",
    "test:billing": "tsx --test src/lib/billing/*.test.ts",
    "db:migrate": "tsx src/drizzle/migrate.ts",
    "preview": "npm run build && npm run start",
    "deploy": "npx vercel --prod",
    "cf:assert-workers": "node scripts/ensure-cloudflare-workers.js",
    "cf:guard-config": "node scripts/guard-cloudflare-config.js",
    "cf:build": "npm run cf:assert-workers && npm run cf:guard-config && node scripts/export-env.js && opennextjs-cloudflare build",
    "cf:preview": "npm run cf:assert-workers && npm run cf:guard-config && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "npm run cf:build && npm run cf:guard-config && npx wrangler deploy --experimental-autoconfig=false",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "clean": "rimraf .next out"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.55.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/lodash.isequal": "^4.5.8",
    "@types/stripe": "^8.0.416",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "lodash.isequal": "^4.5.0",
    "lucide-react": "^0.525.0",
    "motion": "^12.38.0",
    "next": "^14.2.15",
    "next-intl": "^4.3.4",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.0.1",
    "stripe": "^16.12.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "1.8.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "supabase": "^2.77.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.36.0"
  }
}
